{
  "expo": {
    "name": "러닝봄",
    "slug": "runningbom",
    "version": "0.18.0",
    "description": "지역·거리·접수 상태로 러닝 대회를 찾고 공식 접수 시작 알림을 준비하는 러닝봄",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "default",
    "scheme": "runningbom",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.robom.runningbom",
      "buildNumber": "3",
      "infoPlist": {
        "CFBundleDisplayName": "러닝봄"
      },
      "associatedDomains": []
    },
    "android": {
      "package": "kr.robom.runningbom",
      "versionCode": 3,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F4",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "runningbom"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "owner": "robom-labs",
    "extra": {
      "eas": {
        "projectId": "5be5e57e-a1a7-4d08-adf1-2218f38b32a5"
      }
    }
  }
}
