{
  "name": "@robom/runningbom-mobile",
  "version": "0.17.11",
  "main": "index.ts",
  "dependencies": {
    "expo": "~57.0.6",
    "expo-dev-client": "~57.0.6",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "config": "expo config --type public",
    "verify": "node scripts/verify-config.mjs",
    "check": "npm run typecheck && npm run verify && npm run config",
    "export:native": "expo export --platform android --output-dir dist/android && expo export --platform ios --output-dir dist/ios"
  },
  "private": true
}
